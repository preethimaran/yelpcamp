<% layout('layouts/boilerplate') %>

    <div class="row">
        <h1 class="text-center">New Campground</h1>
        <div class="col-md-6 offset-md-3">
            <form action="/campgrounds" method="post" novalidate class="needs-validation" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="title" class="form-label">Enter the title</label>
                    <input type="text" class="form-control" name="campground[title]" id="title" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label for="location" class="form-label">Enter the location</label>
                    <input type="text" class="form-control" name="campground[location]" id="location" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <!-- <div class="mb-3">
                <label for="image" class="form-label">Enter the Image URL</label>
                <input type="text" class="form-control" name="campground[image]" id="image" required>
                <div class="valid-feedback">
                    Looks good!
                </div>
            </div> -->
                <div class="mb-3">
                    <label for="image" class="form-label">Add Images</label>
                    <input class="form-control" type="file" name="image" id="image" multiple required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <!-- <div class="mb-3">
                <input type="file" name="image" multiple>
            </div> -->
                <div class="mb-3">
                    <label for="description" class="form-label">Enter the description</label>
                    <textarea type="text" class="form-control" name="campground[description]" id="description"
                        required></textarea>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label for="price" class="form-label">Enter Price</label>
                    <div class="input-group">
                        <span id="price-dollar " class="input-group-text">$</span>
                        <input type="text" class="form-control" name="campground[price]" id="price" placeholder="0.00"
                            aria-describedby="price-dollar" required>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <button class="btn btn-info w-100">Add Campground</button>
                </div>
            </form>

            <a href="/campgrounds">All Campgrounds</a>

        </div>
    </div>